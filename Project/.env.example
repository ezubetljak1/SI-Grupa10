# Copy this file to .env on the deployment server and update the values.
# Do not commit the real .env file.

POSTGRES_DB=docflow
POSTGRES_USER=docflow_user
POSTGRES_PASSWORD=change_me_strong_password

SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

DOCFLOW_MAX_FILE_SIZE=10485760

FRONTEND_PORT=80
CLIENT_MAX_BODY_SIZE=20M

# Google Document AI configuration
# Set these values locally or on the deployment server.
# Do not commit the service account JSON key file.

GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id
GOOGLE_DOCUMENT_AI_LOCATION=eu
GOOGLE_DOCUMENT_AI_ENDPOINT=eu-documentai.googleapis.com:443

GOOGLE_DOCUMENT_AI_CLASSIFIER_PROCESSOR_ID=id_classifier

GOOGLE_DOCUMENT_AI_INVOICE_PROCESSOR_ID=id_invoice_processor
GOOGLE_DOCUMENT_AI_RECEIPT_PROCESSOR_ID=id_expense_processor
GOOGLE_DOCUMENT_AI_BANK_STATEMENT_PROCESSOR_ID=id_bank_statement_processor
GOOGLE_DOCUMENT_AI_FORM_PROCESSOR_ID=id_form_processor