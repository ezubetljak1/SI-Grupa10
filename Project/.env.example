# Copy this file to .env on the deployment server and update the values.
# Do not commit the real .env file.

POSTGRES_DB=docflow
POSTGRES_USER=docflow_user
POSTGRES_PASSWORD=change_me_strong_password

SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

DOCFLOW_MAX_FILE_SIZE=10485760

FRONTEND_PORT=80
CLIENT_MAX_BODY_SIZE=20M

# Google Document AI configuration
# Set these values locally or on the deployment server.
# Do not commit the service account JSON key file.

GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id
GOOGLE_DOCUMENT_AI_LOCATION=eu
GOOGLE_DOCUMENT_AI_ENDPOINT=eu-documentai.googleapis.com:443

GOOGLE_DOCUMENT_AI_CLASSIFIER_PROCESSOR_ID=id_classifier

GOOGLE_DOCUMENT_AI_INVOICE_PROCESSOR_ID=id_invoice_processor
GOOGLE_DOCUMENT_AI_RECEIPT_PROCESSOR_ID=id_expense_processor
GOOGLE_DOCUMENT_AI_BANK_STATEMENT_PROCESSOR_ID=id_bank_statement_processor
GOOGLE_DOCUMENT_AI_FORM_PROCESSOR_ID=id_form_processor

# Keycloak configuration
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change_me_keycloak_password
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin_password
KEYCLOAK_PORT=8081

DOCFLOW_KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/docflow
DOCFLOW_KEYCLOAK_JWK_SET_URI=http://localhost:8081/realms/docflow/protocol/openid-connect/certs
DOCFLOW_KEYCLOAK_REALM=docflow
DOCFLOW_KEYCLOAK_SERVER_URL=http://localhost:8081
DOCFLOW_KEYCLOAK_FRONTEND_CLIENT_ID=docflow-frontend
DOCFLOW_KEYCLOAK_BACKEND_ADMIN_CLIENT_ID=docflow-backend-admin
DOCFLOW_KEYCLOAK_BACKEND_ADMIN_CLIENT_SECRET=change_me_later 

# Spring Mail configuration for Docflow notification reminders
# Do not commit real SMTP credentials.
DOCFLOW_SMTP_HOST=smtp-relay.brevo.com
DOCFLOW_SMTP_PORT=2525
DOCFLOW_SMTP_USERNAME=your-smtp-username
DOCFLOW_SMTP_PASSWORD=your-smtp-password
DOCFLOW_MAIL_FROM=noreply@docflow.page
DOCFLOW_MAIL_FROM_NAME=Docflow

# Notification reminder configuration
DOCFLOW_FRONTEND_BASE_URL=https://docflow.page
DOCFLOW_EMAIL_REMINDER_ENABLED=true
DOCFLOW_EMAIL_REMINDER_AFTER_HOURS=24
DOCFLOW_EMAIL_REMINDER_CRON=0 0 * * * *