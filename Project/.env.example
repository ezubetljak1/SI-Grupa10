# Copy this file to .env on the deployment server and update the values.
# Do not commit the real .env file.

POSTGRES_DB=docflow
POSTGRES_USER=docflow_user
POSTGRES_PASSWORD=change_me_strong_password

SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

DOCFLOW_MAX_FILE_SIZE=10485760

FRONTEND_PORT=80
CLIENT_MAX_BODY_SIZE=20M

# vrijednosti za lokalno pokretanje (promijeniti po potrebi)
# promijeniti na serveru kad se kopira u .env

GOOGLE_CLOUD_PROJECT_ID=sixth-drive-495508-u3
GOOGLE_DOCUMENT_AI_LOCATION=eu
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=422023381c17ede6
GOOGLE_DOCUMENT_AI_ENDPOINT=eu-documentai.googleapis.com:443
GOOGLE_APPLICATION_CREDENTIALS=C:\docflow-secrets\google-document-ai.json